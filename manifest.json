{
  "manifest_version": 3,
  "name": "Kannada Character Breakdown",
  "version": "1.0",
  "description": "Translate English words to Kannada and see character-by-character breakdown on selection.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
